PORT=4000

# MongoDB Atlas (recommended)
# Example:
# mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/alu-satu?retryWrites=true&w=majority&appName=<cluster-name>
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/alu-satu?retryWrites=true&w=majority

# Mongo connection timeout (ms)
MONGO_CONNECT_TIMEOUT_MS=10000

# Required for auth token signing
JWT_SECRET=your_jwt_secret_here

# Comma-separated additional frontend origins (merged with built-in defaults)
ALLOWED_ORIGINS=https://akaiaksai.app,https://www.akaiaksai.app,https://akaiaksai.github.io
